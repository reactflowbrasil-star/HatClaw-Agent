{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "powershell": "./scripts/commit-gate.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "powershell": "./scripts/setup-check.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "powershell": "./scripts/test-reminder.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "powershell": "./scripts/doc-sync.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
