{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "entraTenantId": {
      "value": "${ENTRA_TENANT_ID}"
    },
    "serviceManagementReference": {
      "value": "${ENTRA_SERVICE_MANAGEMENT_REFERENCE=}"
    },
    "webImageName": {
      "value": "${SERVICE_WEB_IMAGE_NAME=}"
    },
    "aiAgentEndpoint": {
      "value": "${AI_AGENT_ENDPOINT=}"
    },
    "aiAgentId": {
      "value": "${AI_AGENT_ID=}"
    },
    "enableObo": {
      "value": "${ENABLE_OBO=false}"
    }
  }
}
