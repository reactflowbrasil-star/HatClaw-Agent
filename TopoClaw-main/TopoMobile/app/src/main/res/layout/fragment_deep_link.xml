<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 标题栏 -->
    <LinearLayout
        android:id="@+id/llTitleBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:elevation="4dp"
        android:fitsSystemWindows="false">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back"
            android:tint="@android:color/black"
            android:padding="12dp"
            android:layout_marginStart="-8dp" />
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/deep_link_title"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:gravity="center" />
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- 内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="16dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link_input_hint"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/deep_link_input_placeholder"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etActivityComponent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:imeOptions="actionDone"
                    android:minLines="2"
                    android:maxLines="6"
                    android:scrollHorizontally="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnJump"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link_jump"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tvPresetCasesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link_preset_cases_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPresetCasesHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link_preset_cases_hint"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/llPresetCases"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvPermissionShortcutsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link_permission_shortcuts_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPermissionShortcutsHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link_permission_shortcuts_hint"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/llPermissionShortcuts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
