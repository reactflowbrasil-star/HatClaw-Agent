<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:background="@drawable/feedback_card_background">

    <!-- 评价标题 -->
    <TextView
        android:id="@+id/tvFeedbackTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_title"
        android:textSize="16sp"
        android:textColor="#FF333333"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:lineSpacingExtra="2dp" />

    <!-- 星星评分容器 -->
    <LinearLayout
        android:id="@+id/llStarRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/btnStar1"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="1星"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:scaleType="fitCenter" />

        <ImageButton
            android:id="@+id/btnStar2"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="2星"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:scaleType="fitCenter" />

        <ImageButton
            android:id="@+id/btnStar3"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="3星"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:scaleType="fitCenter" />

        <ImageButton
            android:id="@+id/btnStar4"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="4星"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:scaleType="fitCenter" />

        <ImageButton
            android:id="@+id/btnStar5"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="5星"
            android:padding="8dp"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- 评价输入框 -->
    <EditText
        android:id="@+id/etFeedbackText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:hint="@string/feedback_hint"
        android:textSize="14sp"
        android:textColor="#FF333333"
        android:textColorHint="#FF999999"
        android:background="@drawable/feedback_input_background"
        android:padding="12dp"
        android:gravity="top|start"
        android:inputType="textMultiLine|textCapSentences"
        android:maxLines="5"
        android:scrollbars="vertical"
        android:layout_marginBottom="16dp" />

    <!-- 按钮容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:baselineAligned="false">

        <!-- 取消按钮 -->
        <Button
            android:id="@+id/btnCancelFeedback"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textSize="@dimen/feedback_button_text_size"
            android:textColor="#FF666666"
            android:background="@drawable/feedback_button_cancel"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_marginEnd="6dp"
            android:stateListAnimator="@null"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 客服按钮 -->
        <Button
            android:id="@+id/btnCustomerService"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/feedback_customer_service"
            android:textSize="@dimen/feedback_button_text_size"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/feedback_button_secondary"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:stateListAnimator="@null"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 发送按钮 -->
        <Button
            android:id="@+id/btnSendFeedback"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/send"
            android:textSize="@dimen/feedback_button_text_size"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/feedback_button_primary"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_marginStart="6dp"
            android:stateListAnimator="@null"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
