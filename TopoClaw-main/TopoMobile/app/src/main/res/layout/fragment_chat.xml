<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <!-- 标题栏 -->
    <LinearLayout
        android:id="@+id/llTitleBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:fitsSystemWindows="false">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back"
            android:tint="@android:color/black"
            android:padding="12dp"
            android:layout_marginStart="-8dp" />
        <TextView
            android:id="@+id/tvConversationName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/chat"
            android:textSize="15sp"
            android:textColor="@android:color/black"
            android:gravity="center" />
        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more_vert"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_more"
            android:tint="@android:color/black"
            android:padding="12dp" />
    </LinearLayout>

    <!-- 系统消息标题行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F9F9F9"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">
        
        <!-- 系统消息标题（可点击展开/折叠，默认隐藏） -->
        <TextView
            android:id="@+id/tvSystemMessagesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/system_messages_0"
            android:textSize="11sp"
            android:textColor="#333333"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:paddingEnd="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 系统消息固定容器（在标题栏下方，不随聊天内容滚动） -->
    <LinearLayout
        android:id="@+id/llSystemMessagesContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F9F9F9"
        android:visibility="gone">
        
        <!-- 系统消息内容容器（默认隐藏，带滚动和最大高度限制） -->
        <ScrollView
            android:id="@+id/svSystemMessagesContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:visibility="gone"
            android:background="#F9F9F9"
            android:scrollbars="vertical"
            android:fadeScrollbars="false">
            <LinearLayout
                android:id="@+id/llSystemMessagesContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </ScrollView>
    </LinearLayout>

    <!-- 聊天内容区域 -->
    <LinearLayout
        android:id="@+id/llChatContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp">

        <!-- 聊天消息列表和推荐面板的容器（使用FrameLayout让推荐面板覆盖在聊天消息列表之上） -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            
            <!-- 聊天消息列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChatMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:background="#F9F9F9"
                android:paddingTop="8dp"
                android:paddingBottom="28dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:clipToPadding="false" />
            
            <!-- 滚动到底部按钮（当不在底部时显示，浮动在推荐面板上方居中） -->
            <ImageButton
                android:id="@+id/btnScrollToBottom"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom|center_horizontal"
                android:src="@drawable/ic_arrow_down"
                android:background="@drawable/scroll_to_bottom_button_background"
                android:contentDescription="@string/cd_scroll_to_bottom"
                android:visibility="gone"
                android:layout_marginBottom="32dp"
                android:elevation="4dp"
                android:padding="6dp"
                android:tint="#666666" />
            
            <!-- 推荐任务上拉弹窗（输入框上方，浮动在聊天消息列表之上） -->
            <LinearLayout
                android:id="@+id/llRecommendationsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:visibility="visible"
                android:background="@android:color/transparent"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">
            
            <!-- 按钮容器（水平布局，包含"更多"、"猜你想做"和"Beta"按钮） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center_vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp">

                <!-- 自定义小助手专属：更多/侧边栏按钮，仅自定义小助手可见 -->
                <TextView
                    android:id="@+id/btnCustomAssistantMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/custom_assistant_more"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:lineSpacingMultiplier="1.0"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/recommendations_button_selector"
                    android:visibility="gone" />

                <!-- 弹窗头部（可点击展开/收起）- 浅蓝色圆角按钮样式，宽度包裹内容 -->
                <LinearLayout
                    android:id="@+id/llRecommendationsHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/recommendations_button_selector">
                    
                    <TextView
                        android:id="@+id/tvRecommendationsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/guess_you_want"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"
                        android:lineSpacingMultiplier="1.0"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp" />
                </LinearLayout>
                
                <!-- Beta按钮 -->
                <TextView
                    android:id="@+id/tvProButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/beta"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:lineSpacingMultiplier="1.0"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/recommendations_button_selector" />
                
                <!-- 新话题按钮 -->
                <TextView
                    android:id="@+id/btnNewTopic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/new_topic"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:lineSpacingMultiplier="1.0"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/recommendations_button_selector"
                    android:visibility="gone" />
                
                <!-- 筛选用户按钮（仅管理员模式显示） -->
                <TextView
                    android:id="@+id/btnFilterUsers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_users"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="0dp"
                    android:lineSpacingMultiplier="1.0"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/recommendations_button_selector"
                    android:visibility="gone" />
            </LinearLayout>
            
            <!-- 推荐任务列表（默认隐藏） -->
            <LinearLayout
                android:id="@+id/llRecommendationsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                android:background="#F9F9F9"
                android:elevation="2dp">
                
                <!-- 推荐任务会动态添加到这里 -->
            </LinearLayout>
        </LinearLayout>
        </FrameLayout>
        
        <!-- 图片预览区域（输入框上方靠左，小图标） -->
        <FrameLayout
            android:id="@+id/llImagePreview"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:visibility="gone"
            android:layout_marginBottom="0dp"
            android:layout_gravity="start">
            
            <ImageView
                android:id="@+id/ivSelectedImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="已选择的图片"
                android:clickable="true"
                android:focusable="true" />
            
            <ImageButton
                android:id="@+id/btnRemoveImage"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@android:drawable/dialog_holo_dark_frame"
                android:contentDescription="删除图片"
                android:padding="3dp"
                android:tint="#FFFFFFFF"
                android:layout_margin="3dp" />
        </FrameLayout>

        <!-- 聊天输入框、下拉箭头和发送按钮 -->
        <LinearLayout
            android:id="@+id/llInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="4dp">
            
            <!-- 语音输入按钮 -->
            <ImageButton
                android:id="@+id/btnVoiceInput"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_mic"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="语音输入"
                android:padding="8dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="4dp"
                android:layout_gravity="center_vertical" />
            
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etChatInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="textMultiLine"
                android:hint="@string/input_hint"
                android:minLines="1"
                android:maxLines="3"
                android:padding="16dp"
                android:background="@android:drawable/edit_text"
                android:textSize="14sp" />
            
            <!-- 图标容器：将下拉箭头和按钮图标紧凑地放在一起 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp">
                
                <ImageButton
                    android:id="@+id/btnQueryDropdown"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_emoji"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="表情"
                    android:padding="8dp"
                    android:layout_marginEnd="0dp" />
                
                <!-- 按钮容器：发送按钮和结束按钮横向排列 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_vertical">
                    
                    <!-- 加号按钮（键盘未弹起时显示） -->
                    <ImageButton
                        android:id="@+id/btnAddMedia"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_add"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="添加媒体"
                        android:padding="8dp"
                        android:layout_marginEnd="0dp"
                        android:visibility="visible" />
                    
                    <!-- 发送按钮（键盘弹起时显示） -->
                    <ImageButton
                        android:id="@+id/btnSendChat"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_send"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="发送"
                        android:padding="8dp"
                        android:layout_marginStart="-4dp"
                        android:layout_marginEnd="0dp"
                        android:visibility="gone" />
                    
                    <ImageButton
                        android:id="@+id/btnStopTask"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_stop"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="结束任务"
                        android:padding="8dp"
                        android:layout_marginStart="-4dp"
                        android:layout_marginEnd="0dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        
        <!-- 媒体选择面板（初始隐藏） -->
        <LinearLayout
            android:id="@+id/llMediaPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="16dp"
            android:visibility="gone"
            android:minHeight="120dp"
            android:elevation="8dp">
            
            <!-- 图标行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                
                <!-- 图片选项 -->
                <LinearLayout
                    android:id="@+id/llImageOption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_image"
                        android:contentDescription="图片" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/image"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
                
                <!-- 视频选项 -->
                <LinearLayout
                    android:id="@+id/llVideoOption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_video"
                        android:contentDescription="视频" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/video"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
                
                <!-- 技能选项 -->
                <LinearLayout
                    android:id="@+id/llSkillOption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_skill"
                        android:contentDescription="技能" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/skill"
                        android:textSize="12sp"
                        android:textColor="#FF000000"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        
        <!-- 表情选择面板（初始隐藏） -->
        <LinearLayout
            android:id="@+id/llEmojiPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:visibility="gone"
            android:minHeight="200dp"
            android:elevation="8dp">
            
            <android.widget.GridView
                android:id="@+id/gvEmoji"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:numColumns="8"
                android:horizontalSpacing="4dp"
                android:verticalSpacing="4dp"
                android:stretchMode="columnWidth"
                android:gravity="center" />
        </LinearLayout>
        
        <!-- 语音录制面板（初始隐藏） -->
        <LinearLayout
            android:id="@+id/llVoicePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="32dp"
            android:visibility="gone"
            android:minHeight="200dp"
            android:elevation="8dp"
            android:gravity="center">
            
            <!-- 提示文字 -->
            <TextView
                android:id="@+id/tvVoiceHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_speak"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="24dp"
                android:gravity="center" />
            
            <!-- 麦克风按钮容器 -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center">
                
                <!-- 转圈特效（录音时显示） -->
                <com.cloudcontrol.demo.RecordingRingView
                    android:id="@+id/ivRecordingRing"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:visibility="gone"
                    android:layout_gravity="center" />
                
                <!-- 麦克风按钮（点击开始录音） -->
                <ImageButton
                    android:id="@+id/btnVoiceRecord"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_mic"
                    android:background="@drawable/voice_record_button_background"
                    android:contentDescription="点击录音"
                    android:paddingTop="22dp"
                    android:paddingBottom="18dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:scaleType="fitCenter"
                    android:tint="#FFFFFF"
                    android:layout_gravity="center" />
            </FrameLayout>
        </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 自定义小助手侧边栏 overlay，点击半透明背景关闭 -->
    <FrameLayout
        android:id="@+id/overlayCustomAssistantDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/customAssistantDrawerScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:id="@+id/customAssistantDrawerPanel"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <!-- 开启新对话按钮 -->
            <LinearLayout
                android:id="@+id/btnCustomAssistantNewSession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/recommendations_button_selector"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_add"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@string/session_new"
                    android:tint="#666666" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/session_new"
                    android:textSize="14sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <!-- 历史对话列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCustomAssistantSessions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:scrollbars="vertical"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
