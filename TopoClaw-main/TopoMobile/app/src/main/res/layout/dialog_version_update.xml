<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/dialog_background_rounded"
    android:minWidth="320dp"
    android:maxWidth="400dp">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="发现新版本"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:letterSpacing="0.02" />

    <!-- 版本信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:id="@+id/tvCurrentVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前版本：1.0"
            android:textSize="14sp"
            android:textColor="#757575" />
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" → "
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />
        
        <TextView
            android:id="@+id/tvLatestVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="最新版本：1.0"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 更新说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="更新说明："
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="8dp" />
    
    <!-- 更新消息 -->
    <TextView
        android:id="@+id/tvUpdateMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="发现新版本，建议更新"
        android:textSize="14sp"
        android:textColor="#212121"
        android:gravity="start"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="24dp" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">
        
        <Button
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂不更新"
            android:textColor="#757575"
            android:textSize="14sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginEnd="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:minHeight="48dp"
            android:minWidth="90dp"
            android:visibility="visible" />
        
        <Button
            android:id="@+id/btnUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="立即更新"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:minHeight="40dp"
            android:minWidth="70dp"
            android:background="@drawable/button_send_background"
            android:elevation="2dp" />
    </LinearLayout>

</LinearLayout>

