<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 标题栏 -->
    <LinearLayout
        android:id="@+id/llTitleBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:elevation="4dp"
        android:fitsSystemWindows="false">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back"
            android:tint="@android:color/black"
            android:padding="12dp"
            android:layout_marginStart="-8dp" />
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/more_service_settings"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:gravity="center" />
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- 内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="16dp"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 云侧服务地址输入和下拉箭头 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/server_url_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:hint="@string/server_url_hint" />
                </com.google.android.material.textfield.TextInputLayout>
                
                <ImageButton
                    android:id="@+id/btnServerUrlDropdown"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_arrow_drop_down"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_history_address"
                    android:padding="12dp"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>

            <!-- 按钮区域：切换云侧服务地址 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                
                <Button
                    android:id="@+id/btnApplyServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/switch_cloud_address" />
            </LinearLayout>

            <!-- 快捷设置按钮区域：两行两列布局 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                
                <!-- 第一行：开启无障碍服务 和 授权截图权限 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <Button
                        android:id="@+id/btnOpenAccessibility"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/enable_accessibility"
                        android:layout_marginEnd="8dp" />
                    
                    <Button
                        android:id="@+id/btnRequestChatPermission"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/grant_screenshot" />
                </LinearLayout>
                
                <!-- 第二行：授权悬浮窗权限 和 授权通知权限 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    
                    <Button
                        android:id="@+id/btnRequestOverlayPermission"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/grant_overlay"
                        android:layout_marginEnd="8dp" />
                    
                    <Button
                        android:id="@+id/btnRequestNotificationPermission"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/grant_notification" />
                </LinearLayout>
                
                <!-- 第三行：授权麦克风权限 和 授予地理位置权限（NETWORK） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    
                    <Button
                        android:id="@+id/btnRequestMicrophonePermission"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/grant_microphone" />

                    <Button
                        android:id="@+id/btnRequestNetworkLocationPermission"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/grant_network_location" />
                </LinearLayout>
            </LinearLayout>

            <!-- 测试入口 -->
            <Button
                android:id="@+id/btnTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/test"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnClipboardImageTest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/clipboard_image_test"
                android:layout_marginBottom="16dp" />

            <!-- 轨迹采集设置入口 -->
            <Button
                android:id="@+id/btnTrajectorySettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/trajectory_collection"
                android:layout_marginBottom="16dp" />

            <!-- Deep Link 入口 -->
            <Button
                android:id="@+id/btnDeepLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deep_link"
                android:layout_marginBottom="16dp" />

            <!-- 获取当前位置测试入口 -->
            <Button
                android:id="@+id/btnGetCurrentLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/get_current_location"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvLocationAmapNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/location_amap_notice"
                android:textColor="#666666"
                android:textSize="12sp" />

            <!-- 地理位置变化监视测试模式 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/location_monitor_test_mode"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <Switch
                    android:id="@+id/switchLocationMonitorTestMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llLocationMonitorTestStartAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/location_monitor_test_start_address_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLocationMonitorTestStartAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:hint="@string/location_monitor_test_start_address_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSaveLocationMonitorTestStartAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/location_monitor_test_start_address_save" />

                <Button
                    android:id="@+id/btnTriggerLocationMonitorCheckNow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/location_monitor_check_now" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvLocationMonitorLogsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/location_monitor_logs_title"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRefreshLocationMonitorLogs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/location_monitor_logs_refresh" />

                <Button
                    android:id="@+id/btnClearLocationMonitorLogs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/location_monitor_logs_clear" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLocationMonitorLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#FFF5F5F5"
                android:padding="10dp"
                android:text="@string/location_monitor_logs_empty"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:typeface="monospace" />

            <!-- 默认允许好友控制手机开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/allow_friend_control_by_default"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchAllowFriendControlByDefault"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 打开应用时回到主页开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/back_to_home"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchOpenActionClearTop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 新任务开始前清除后台应用开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/clear_before_task"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchClearBackgroundBeforeTask"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 录制前清除后台应用开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/clear_before_record"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchClearBackgroundBeforeRecording"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 任务运行悬浮窗开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/task_floating_window"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchTaskIndicatorOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 开启伴随模式开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/enable_companion_mode"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchCompanionMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 端侧变化检测开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/change_detection"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchSendBeforeActionImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 边框特效开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/border_effect"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchBorderEffect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 网格激活特效开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/grid_activation_effect"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchGridActivationEffect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 展示推理过程开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_reasoning"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchReasoningOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 任务执行时监视剪切板开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/clipboard_monitor"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchClipboardMonitor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 监视通知栏开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/notification_monitor"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <Switch
                    android:id="@+id/switchNotificationMonitor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <Button
                android:id="@+id/btnNotificationMonitorExcludedApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notification_monitor_excluded_apps"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <!-- 显示键盘UI开关 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_keyboard_ui"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />
                
                <Switch
                    android:id="@+id/switchShowKeyboardUI"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 动作完成后延迟时间设置 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/action_delay_hint"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />
                
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/action_delay_default_hint">
                    
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etActionCompletionDelay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="@string/action_delay_input_hint" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 截图上云宽高缩放系数 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/screenshot_compression_ratio_hint"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/screenshot_compression_ratio_hint_short">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etScreenshotCompressionRatio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="@string/screenshot_compression_ratio_input_hint" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 云侧 API 读取超时（等云侧回包） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cloud_api_read_timeout_hint"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/cloud_api_read_timeout_hint_short">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCloudApiReadTimeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="@string/cloud_api_read_timeout_input_hint" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- 是否获取已安装应用开关（传递给云侧，MVP格式） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/fetch_installed_apps_for_cloud"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <Switch
                    android:id="@+id/switchFetchInstalledAppsForCloud"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 切换到 next_action 接口 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/use_next_action_api"
                    android:textSize="16sp"
                    android:gravity="center_vertical" />

                <Switch
                    android:id="@+id/switchUseNextActionApi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/switch_thumb_tint_blue"
                    android:trackTint="@color/switch_track_tint_blue" />
            </LinearLayout>

            <!-- 已安装应用包名入口 -->
            <Button
                android:id="@+id/btnInstalledPackages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/installed_packages"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- 扩展服务地址设置（人工客服/聊天小助手/技能社区） -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/extra_service_url_settings"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/customer_service_url_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCustomerServiceUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:hint="@string/customer_service_url_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/chat_assistant_url_label"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etChatAssistantUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:hint="@string/chat_assistant_url_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/skill_community_url_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSkillCommunityUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:hint="@string/skill_community_url_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnApplyExtraServiceUrls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/apply_extra_service_urls" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

