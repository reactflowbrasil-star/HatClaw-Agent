<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- 标题栏 -->
    <LinearLayout
        android:id="@+id/llTitleBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:elevation="4dp"
        android:fitsSystemWindows="false">
        
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:tint="@android:color/black"
            android:padding="12dp"
            android:layout_marginStart="-8dp" />
            
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/floating_ball"
            android:textSize="18sp"
            android:textColor="@android:color/black"
            android:gravity="center" />
            
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- 内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="24dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <!-- 一级标题 -->
            <TextView
                android:id="@+id/tvFloatingBallTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/floating_ball"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:paddingBottom="16dp" />
            
            <!-- 文字内容 -->
            <TextView
                android:id="@+id/tvFloatingBallContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tip_floating_ball_content"
                android:textSize="16sp"
                android:textColor="#424242"
                android:lineSpacingMultiplier="1.4"
                android:paddingBottom="24dp" />
            
            <!-- 图片容器 - 使用HorizontalScrollView支持横向滑动 -->
            <HorizontalScrollView
                android:id="@+id/scrollViewFloatingBallImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:fadeScrollbars="true"
                android:fillViewport="true"
                android:gravity="center">
                
                <LinearLayout
                    android:id="@+id/layoutFloatingBallImages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical|center_horizontal"
                    android:minHeight="300dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    
                    <!-- 图片将动态添加到这里 -->
                    
                </LinearLayout>
                
            </HorizontalScrollView>
            
            <!-- 图片滑动指示器 - 当图片数量>2时显示 -->
            <LinearLayout
                android:id="@+id/layoutFloatingBallImageIndicators"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />
            
        </LinearLayout>
    </ScrollView>

</LinearLayout>

