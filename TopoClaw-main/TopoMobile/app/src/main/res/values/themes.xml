<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TopoClaw.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/topoclaw_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.TopoClaw</item>
    </style>

    <style name="Theme.TopoClaw" parent="Theme.MaterialComponents.DayNight">
        <!-- 主色调：浅绿色（微信风格） -->
        <item name="colorPrimary">@color/wechat_green</item>
        <item name="colorPrimaryVariant">@color/wechat_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- ActionBar背景色：白色 -->
        <item name="android:actionBarStyle">@style/WhiteActionBar</item>
        
        <!-- 辅助色：浅蓝色（微信风格） -->
        <item name="colorSecondary">@color/wechat_blue</item>
        <item name="colorSecondaryVariant">@color/wechat_blue_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- 状态栏颜色：白色 -->
        <item name="android:statusBarColor">@android:color/white</item>
        <!-- 状态栏图标颜色：深色（因为背景是白色） -->
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- 背景色：浅灰色（微信风格） -->
        <item name="android:windowBackground">#FFF5F5F5</item>
    </style>
    
    <!-- 白色ActionBar样式 -->
    <style name="WhiteActionBar" parent="Widget.MaterialComponents.ActionBar.Primary">
        <item name="android:background">@android:color/white</item>
        <item name="titleTextStyle">@style/WhiteActionBarTitle</item>
    </style>
    
    <!-- ActionBar标题文字样式 -->
    <style name="WhiteActionBarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textStyle">normal</item>
    </style>
</resources>

